# ==================== 阶段1：构建阶段（安装依赖，生成虚拟环境） ====================
# 基础镜像：官方 uv 镜像，自带 uv 工具，Python 3.12 + Debian Bookworm
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS builder

WORKDIR /app

# 【关键】仅复制依赖配置文件，利用 Docker 缓存避免代码变动后重复安装依赖
COPY pyproject.toml uv.lock ./

# 严格按照 uv.lock 复现虚拟环境
# --frozen：强制使用锁文件，禁止版本浮动
# --no-dev：不安装开发依赖（如测试、格式化工具等）
# --no-install-project：仅安装第三方依赖，暂不安装项目自身
RUN uv sync \
    --frozen \
    --no-dev \
    --no-install-project

# ==================== 阶段2：运行阶段（轻量运行时镜像） ====================
# 基础镜像：官方 Python 轻量镜像
FROM docker.1ms.run/library/python:3.12-slim-bookworm

WORKDIR /app

# 【关键】从构建阶段复制已生成的虚拟环境（完整复现依赖）
COPY --from=builder /app/.venv ./.venv

# 复制所有业务代码文件（可按需改为 COPY src/ ./src/ 等）
COPY . .

# 配置环境变量：让系统优先使用容器内的虚拟环境
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app:$PYTHONPATH"

# ==================== 无默认启动命令 ====================
# 不编写 CMD / ENTRYPOINT，完全由运行时（如 docker run 或 compose）指定启动命令